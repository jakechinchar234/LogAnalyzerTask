
"""
NonGenericComponentDetector

Handles NON-generic Packetswitch HTML files with:
- RED text (ON)  → via CSS / inherited
- STRIKETHROUGH (OFF)

Also supports RAW files (no color):
→ defaults components to ON

Returns:
    {(time_tag, 'Ind'|'Control'|'Recall'): "component On / component Off"}
"""

import re
from typing import Dict, Tuple
from bs4 import BeautifulSoup


# =========================
# HELPERS
# =========================


def is_red(node):
    """Detect ON using actual HTML attribute color='red'."""
    while node is not None:
        try:
            if hasattr(node, "attrs"):
                # direct attribute check (this is your real case)
                if node.get("color") == "red":
                    return True

                # fallback safety (if format varies slightly)
                attrs = str(node.attrs).lower()
                if "color" in attrs and "red" in attrs:
                    return True

        except Exception:
            pass

        node = getattr(node, "parent", None)

    return False



def is_strike(node):
    """Check if node represents OFF (strike)."""
    while node is not None:
        try:
            if getattr(node, "name", "") == "strike":
                return True

            if hasattr(node, "attrs"):
                attrs = str(node.attrs).lower()
                if "line-through" in attrs:
                    return True
        except Exception:
            pass

        node = getattr(node, "parent", None)

    return False


def is_valid_component(token: str):
    return bool(
        re.match(r"\d+[A-Z]+", token) or   # 17NWZ, 3WLK
        re.match(r"[A-Z]{3,}", token) or   # DOORX, etc.
        ("(" in token and ")" in token)
    )



# =========================
# CORE PARSER
# =========================

def parse_html_with_colors(file_path: str) -> Dict[Tuple[str, str], str]:
    comp_map: Dict[Tuple[str, str], str] = {}

    with open(file_path, "r", encoding="utf-8", errors="ignore") as f:
        html = f.read()

    soup = BeautifulSoup(html, "html.parser")

    # Detect if file contains ANY color info
    has_color = "rgb(" in html or "color:" in html

    for tag in soup.find_all(True):
        line = tag.get_text(strip=True)

        match = re.match(r"P\d+\s+(\d{2}:\d{2}:\d{2})\s+_(..)", line)
        if not match:
            continue

        time_tag = match.group(1)
        raw_code = match.group(2)

        if raw_code == "IR":
            msg_type = "Ind"
        elif raw_code == "CR":
            msg_type = "Control"
        elif raw_code == "R_":
            msg_type = "Recall"
        else:
            continue

        components = []
        seen = set()  # prevent duplicates

        for child in tag.descendants:

            if not hasattr(child, "get_text"):
                continue

            text = child.get_text(strip=True)
            if not text:
                continue

            tokens = [t.strip(", ") for t in text.split() if t.strip()]

            for token in tokens:

                if not is_valid_component(token):
                    continue

                if token in seen:
                    continue

                # OFF (highest priority)
                if is_strike(child):
                    components.append(f"{token} Off")
                    seen.add(token)

                # ON (explicit red)
                elif is_red(child):
                    components.append(f"{token} On")
                    seen.add(token)

                # RAW FALLBACK (no color anywhere in file)
                elif not has_color:
                    components.append(f"{token} On")
                    seen.add(token)

                # Otherwise ignore (blue/green/etc)

        if components:
            comp_map[(time_tag, msg_type)] = " / ".join(components)

            # DEBUG
            # print("FINAL:", (time_tag, msg_type), components[:6])

    return comp_map


# =========================
# PUBLIC API
# =========================

def build_component_map_non_generic(packetswitch_file_path: str):
    return parse_html_with_colors(packetswitch_file_path)
